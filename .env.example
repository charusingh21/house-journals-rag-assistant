# NVIDIA RAG Blueprint endpoints.
# For the GPU Brev demo, these point to services running inside the same instance.
RAG_API_URL=http://127.0.0.1:8081/v1/generate
INGESTOR_API_URL=http://127.0.0.1:8082/v1/documents

# RAG collection used by the House Journals demo.
RAG_COLLECTION=house_journals_full_demo

# Model used by the RAG Blueprint generation endpoint.
RAG_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
RAG_MAX_TOKENS=700

# RAG model runtime mode:
# - nvidia_hosted: RAG services run in Docker; models run on NVIDIA-hosted endpoints.
# - docker_self_hosted: RAG services and core NIM model containers run on this GPU machine.
RAG_BACKEND_MODE=nvidia_hosted

# Self-hosted Docker NIM settings. These are used only when
# RAG_BACKEND_MODE=docker_self_hosted.
MODEL_DIRECTORY=/home/ubuntu/.cache/model-cache
LLM_MS_GPU_ID=1
EMBEDDING_MS_GPU_ID=0
RANKING_MS_GPU_ID=0
APP_RETRIEVER_TOPK=6
VECTOR_DB_TOPK=60
LLM_MAX_TOKENS=4096

# UI model profiles for trying different answer-speed/quality modes.
# Format: key=model|max_tokens|label;key=model|max_tokens|label
# Current NVIDIA API Catalog candidates to try:
# - nvidia/nemotron-3-nano-30b-a3b: faster demo mode when available to your key.
# - nvidia/llama-3.3-nemotron-super-49b-v1.5: stronger deep research mode.
RAG_DEFAULT_PROFILE=balanced
RAG_MODEL_PROFILES=fast=nvidia/nemotron-3-nano-30b-a3b|450|Fast demo;balanced=nvidia/llama-3.3-nemotron-super-49b-v1.5|700|Balanced;deep=nvidia/llama-3.3-nemotron-super-49b-v1.5|1100|Deep research

# Local PDF folder used to build the exact bill lookup metadata index.
HOUSE_JOURNALS_SAMPLE_DIR=/opt/house-journals/HouseJournalSample
HOUSE_JOURNALS_INDEX_DB=/opt/house-journals/app/data/house_journals_index.sqlite

# Optional: if set, setup downloads this zip on fresh Brev instances.
# The zip can contain HouseJournalSample/*.pdf or PDFs at the zip root.
HOUSE_JOURNALS_CORPUS_URL=

# Demo default: use the 2025-2026 House Journal slice.
HOUSE_JOURNALS_START_DATE=20250101
HOUSE_JOURNALS_END_DATE=20261231
HOUSE_JOURNALS_LATEST_COUNT=0

# Number of newest indexed PDFs to push into the RAG Blueprint collection.
# Set higher for a larger demo corpus after the first fast smoke test.
HOUSE_JOURNALS_INGEST_LATEST=40

# NVIDIA RAG Blueprint checkout location on the Brev instance.
RAG_BLUEPRINT_DIR=/home/ubuntu/rag

# Required by the NVIDIA RAG Blueprint services, not directly by this UI.
# Do not commit real keys.
NVIDIA_API_KEY=
